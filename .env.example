# 7event - Environment Variables

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com

# Database - SQLite (desenvolvimento)
# DATABASE_URL=sqlite:///db.sqlite3

# Database - PostgreSQL (producao AWS)
# DATABASE_URL=postgresql://sevenevent_user:SenhaForte123@localhost/sevenevent
# Exemplo: postgresql://usuario:senha@host:5432/nome_do_banco

# Email (SMTP)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=seu_email@seudominio.com
EMAIL_HOST_PASSWORD=sua_senha_aqui
DEFAULT_FROM_EMAIL="7event <seu_email@seudominio.com>"

# Login Google (OAuth)
GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mercado Pago
MP_ACCESS_TOKEN=substitua_pelo_seu_access_token
MP_PUBLIC_KEY=substitua_pela_sua_public_key
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://seu-dominio.com/api/v1/webhooks/mercadopago/
MP_TEST_PAYER_EMAIL=
MP_TEST_MODE=false
MP_CURRENCY=BRL
MP_BILLING_DUE_DAY=8
MP_BILLING_CUTOFF_DAY=15
APP_PUBLIC_URL=https://seu-dominio.com
SUBSCRIPTIONS_RECURRING_ENABLED=true
SUBSCRIPTIONS_ENFORCEMENT_ENABLED=false
SUBSCRIPTIONS_CANCEL_AT_PERIOD_END_ENABLED=true
SUBSCRIPTIONS_PAST_DUE_TOLERANCE_DAYS=5

# n8n (gatilho de mensagens/automacoes)
N8N_WHATSAPP_WEBHOOK_URL=http://localhost:5678/webhook-test/welcomesystem
N8N_WHATSAPP_WEBHOOK_TOKEN=

# webhook de execucao da rotina system-reminders (n8n -> 7event)
TASK_REMINDERS_WEBHOOK_TOKEN=

# Stripe
PAYMENT_PROVIDER=stripe
STRIPE_API_KEY=sk_test_substitua_pela_sua_chave
STRIPE_PUBLISHABLE_KEY=pk_test_substitua_pela_sua_chave
STRIPE_WEBHOOK_SECRET=whsec_substitua_pelo_seu_signing_secret
STRIPE_TEST_MODE=true
STRIPE_CURRENCY=brl
